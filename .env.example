# HighwayRetroAI — Environment Variables
# Copy to .env and customise for your hardware

CAMERA_INDEX=1
STEREO_LEFT_INDEX=1
STEREO_RIGHT_INDEX=2
USE_THERMAL=false
USE_TRT=false
SIMULATE_GPS=true
DEFAULT_LAT=28.6139
DEFAULT_LON=77.2090
GPS_NMEA_HOST=127.0.0.1
GPS_NMEA_PORT=50000
SENSOR_POLL_HZ=5
INFERENCE_TARGET_FPS=30
LOG_LEVEL=INFO
DATA_DIR=./data
MODEL_DIR=./models
OUTPUT_DIR=./outputs

# Google Maps JavaScript API key (for 3D satellite driving map in dashboard)
# Get one at: https://console.cloud.google.com/google/maps-apis
# Enable "Maps JavaScript API" for the key
# Falls back to Leaflet satellite view if left as placeholder
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
